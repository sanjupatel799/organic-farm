# Backend Environment Variables

# Database (SQLite - local file path, Railway handles persistence)
# For Railway, this defaults to /data/sqlite.db if not set
DATABASE_URL="file:./dev.db"

# JWT Secret - change this to a secure random string in production
JWT_SECRET="organic-farm-super-secret-key-2024"

# Server Port (Railway sets this automatically)
PORT=4000

# Frontend URL (for CORS - add your Vercel domain after deploy)
FRONTEND_URL="https://organic-farm.vercel.app"

# Cloudinary (for image uploads - optional, app works without it)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (for payments - optional, app falls back to COD)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
